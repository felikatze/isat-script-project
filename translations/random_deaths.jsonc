    {
        "en_raw": "[Heya, stardust! Welcome back!]",
        "en_clean": "[Heya, stardust! Welcome back!]",
        "jp_raw": "[やあ、星くず君！ おかえり！]",
        "jp_clean": "[やあ、星くず君！ おかえり！]",
        "checked": true
    },
    {
        "en_raw": "[Here's something I forgot to mention before. It'll save you time, so it's important, so listen up!]",
        "en_clean": "[Here's something I forgot to mention before. It'll save you time, so it's important, so listen up!]",
        "jp_raw": "[伝え忘れていたことがあったんだ。時間を節約できる、重要なことだ。よく聞いて！]",
        "jp_clean": "[伝え忘れていたことがあったんだ。時間を節約できる、重要なことだ。よく聞いて！]",
        "checked": true
    },
    {
        "en_raw": "[Do you see the House, now? Do you see how you can loop to specific moments, specific places?]",
        "en_clean": "[Do you see the House, now? Do you see how you can loop to specific moments, specific places?]",
        "jp_raw": "[ウツロイの館が見えるかな？ 特定の場所や時間へループで戻れるのは見える？]",
        "jp_clean": "[ウツロイの館が見えるかな？ 特定の場所や時間へループで戻れるのは見える？]",
        "checked": true
    },
    {
        "en_raw": "[Looping backwards in time is a piece of cake for you, but looping FORWARDS in time is going to be a little harder. You're going against the loops' will, after all.]",
        "en_clean": "[Looping backwards in time is a piece of cake for you, but looping FORWARDS in time is going to be a little harder. You're going against the loops' will, after all.]",
        "jp_raw": "[きみにとって、ループで時間を戻すのは簡単なことだ。だけど、時間を前に進めるのは少し難しい。ループの理に反することになるからね。]",
        "jp_clean": "[きみにとって、ループで時間を戻すのは簡単なことだ。だけど、時間を前に進めるのは少し難しい。ループの理に反することになるからね。]",
        "checked": true
    },
    {
        "en_raw": "[To be able to move forwards in time when you die, you'll need to use up some of your Memories!]",
        "en_clean": "[To be able to move forwards in time when you die, you'll need to use up some of your Memories!]",
        "jp_raw": "[死んだときに時間を進めるには、「記憶」を差し出す必要があるんだ！]",
        "jp_clean": "[死んだときに時間を進めるには、「記憶」を差し出す必要があるんだ！]",
        "checked": true
    },
    {
        "en_raw": "[Do you see that little star symbol, at the bottom of the screen? It shows you how many Memories you have at your disposal.]",
        "en_clean": "[Do you see that little star symbol, at the bottom of the screen? It shows you how many Memories you have at your disposal.]",
        "jp_raw": "[画面の下の方に、小さな星の記号があるのが見える？ それは、きみが持っている「記憶」の数だ。]",
        "jp_clean": "[画面の下の方に、小さな星の記号があるのが見える？ それは、きみが持っている「記憶」の数だ。]",
        "checked": true
    },
    {
        "en_raw": "[Trying to get farther than where you just died will cost you some Memories, so make sure you have enough Memories to spend!]",
        "en_clean": "[Trying to get farther than where you just died will cost you some Memories, so make sure you have enough Memories to spend!]",
        "jp_raw": "[死んだ場所から先へ進むには、「記憶」が必要になる。十分な量の「記憶」をとっておいてくれ！]",
        "jp_clean": "[死んだ場所から先へ進むには、「記憶」が必要になる。十分な量の「記憶」をとっておいてくれ！]",
        "checked": true
    },
    {
        "en_raw": "[...Oh, I can sense you're panicking. Don't worry!]",
        "en_clean": "[...Oh, I can sense you're panicking. Don't worry!]",
        "jp_raw": "[...あれ、慌ててるみたいだね。大丈夫！]",
        "jp_clean": "[...あれ、慌ててるみたいだね。大丈夫！]",
        "checked": true
    },
    {
        "en_raw": "[This won't use up the good, fun memories you have of your party. Just the boring, useless memories you have of your battles.]",
        "en_clean": "[This won't use up the good, fun memories you have of your party. Just the boring, useless memories you have of your battles.]",
        "jp_raw": "[仲間とよい時間を過ごした、楽しい記憶は持っていかれない。戦闘に関する退屈で役に立たない記憶だけが使われるんだ。]",
        "jp_clean": "[仲間とよい時間を過ごした、楽しい記憶は持っていかれない。戦闘に関する退屈で役に立たない記憶だけが使われるんだ。]",
        "checked": true
    },
    {
        "en_raw": "[Have you noticed? For each battle you've fought, you've gained one Memory of Skirmish. And those are the memories you can use to loop forwards!]",
        "en_clean": "[Have you noticed? For each battle you've fought, you've gained one Memory of Skirmish. And those are the memories you can use to loop forwards!]",
        "jp_raw": "[気づいたかい？ 戦闘のたびに、「衝突の記憶」が1つ手に入るんだ。それを使えば、ループで時間を前に進められる！]",
        "jp_clean": "[気づいたかい？ 戦闘のたびに、「衝突の記憶」が1つ手に入るんだ。それを使えば、ループで時間を前に進められる！]",
        "checked": true
    },
    {
        "en_raw": "[Over time, you'll fight some battles that'll earn you even more memories. Isn't that neat?]",
        "en_clean": "[Over time, you'll fight some battles that'll earn you even more memories. Isn't that neat?]",
        "jp_raw": "[そのうち、記憶がもっと手に入る戦闘もあるだろう。すてきだと思わないか？]",
        "jp_clean": "[そのうち、記憶がもっと手に入る戦闘もあるだろう。すてきだと思わないか？]",
        "checked": true
    },
    {
        "en_raw": "[Wow, look at me, yapping and yapping. I'll condense all of that information in one sentence!]",
        "en_clean": "[Wow, look at me, yapping and yapping. I'll condense all of that information in one sentence!]",
        "jp_raw": "[おっと、しゃべりすぎたね。今の話をまとめるよ！]",
        "jp_clean": "[おっと、しゃべりすぎたね。今の話をまとめるよ！]",
        "checked": true
    },
    {
        "en_raw": "[To loop forwards in time, you'll need Memories, which you gain every time you win a battle!]",
        "en_clean": "[To loop forwards in time, you'll need Memories, which you gain every time you win a battle!]",
        "jp_raw": "[ループで時間を前に進めるには、記憶が必要だ。記憶は戦闘に勝利すると手に入る！]",
        "jp_clean": "[ループで時間を前に進めるには、記憶が必要だ。記憶は戦闘に勝利すると手に入る！]",
        "checked": true
