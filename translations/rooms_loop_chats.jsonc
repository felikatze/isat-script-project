[
    {
        "en_raw": "\"Are you getting on my nerves on purpose?\"",
        "en_clean": "\"Are you getting on my nerves on purpose?\"",
        "jp_raw": "\"わざと僕の神経を逆なでているのか？\"",
        "jp_clean": "\"わざと僕の神経を逆なでているのか？\"",
        "checked": true
    },
    {
        "en_raw": "Yes, I actually manufactured this personality especially to get on your nerves, stardust!",
        "en_clean": "Yes, I actually manufactured this personality especially to get on your nerves, stardust!",
        "jp_raw": "まあね。僕はきみの神経を逆なでるようにできているんだよ、星くず君！",
        "jp_clean": "まあね。僕はきみの神経を逆なでるようにできているんだよ、星くず君！",
        "checked": true
    },
    {
        "en_raw": "(You can't tell if that's sarcasm or not.)",
        "en_clean": "(You can't tell if that's sarcasm or not.)",
        "jp_raw": "(今のは皮肉なのだろうか。)",
        "jp_clean": "(今のは皮肉なのだろうか。)",
        "checked": true
    },
    {
        "en_raw": "(Either way, it's working really well.)",
        "en_clean": "(Either way, it's working really well.)",
        "jp_raw": "(いずれにせよ、すごく効いてる。)",
        "jp_clean": "(いずれにせよ、すごく効いてる。)",
        "checked": true
    },
    {
        "en_raw": "\"Can you read my thoughts?\"",
        "en_clean": "\"Can you read my thoughts?\"",
        "jp_raw": "\"僕の思考が読めるのか？\"",
        "jp_clean": "\"僕の思考が読めるのか？\"",
        "checked": true
    },
    {
        "en_raw": "Nah, I just have very good intuition!",
        "en_clean": "Nah, I just have very good intuition!",
        "jp_raw": "ううん、勘が鋭いだけ！",
        "jp_clean": "ううん、勘が鋭いだけ！",
        "checked": true
    },
    {
        "en_raw": "Like somehow, I can tell what you're about to say. Soooooo weird.",
        "en_clean": "Like somehow, I can tell what you're about to say. Soooooo weird.",
        "jp_raw": "理由は分からないけど、きみの言わんとすることが分かるんだ。ちょーーーー変だよね。",
        "jp_clean": "理由は分からないけど、きみの言わんとすることが分かるんだ。ちょーーーー変だよね。",
        "checked": true
    },
    {
        "en_raw": "(Suspicious.)",
        "en_clean": "(Suspicious.)",
        "jp_raw": "(あやしい。)",
        "jp_clean": "(あやしい。)",
        "checked": true
    },
    {
        "en_raw": "What, me??? Suspicious??? Say it ain't so!!!!!!",
        "en_clean": "What, me??? Suspicious??? Say it ain't so!!!!!!",
        "jp_raw": "えっ、なに？？ 本当かって？？ 違うって言って！！！",
        "jp_clean": "えっ、なに？？ 本当かって？？ 違うって言って！！！",
        "checked": true
    },
    {
        "en_raw": "(.............................)",
        "en_clean": "(.............................)",
        "jp_raw": "(..................)",
        "jp_clean": "(..................)",
        "checked": true
    },
    {
        "en_raw": "\"Why 'stardust'?\"",
        "en_clean": "\"Why 'stardust'?\"",
        "jp_raw": "\"どうして僕を「星くず」と？\"",
        "jp_clean": "\"どうして僕を「星くず」と？\"",
        "checked": true
    },
    {
        "en_raw": ". . . Because you're what's left, I suppose.",
        "en_clean": ". . . Because you're what's left, I suppose.",
        "jp_raw": "...だって、きみは残されたものだからじゃないかな。",
        "jp_clean": "...だって、きみは残されたものだからじゃないかな。",
        "checked": true
    },
    {//TODO check eng formatting
        "en_raw": "(What's left?)\n\t\t\t\t\t\t\"What's left of what?\"",
        "en_clean": "(What's left?)\t\t\t\t\t\t\"What's left of what?\"",
        "jp_raw": "(残されたもの？) \"何に残されたんだ？\"",
        "jp_clean": "(残されたもの？) \"何に残されたんだ？\"",
        "checked": false
    },
    {
        "en_raw": "And because it's a cute nickname! You're my little stardust! My little cutie patootie stardust!",
        "en_clean": "And because it's a cute nickname! You're my little stardust! My little cutie patootie stardust!",
        "jp_raw": "それに、かわいいあだ名だろ！ 僕のかわいい星くず君！ 僕のちっちゃなかわいい星くず君！",
        "jp_clean": "それに、かわいいあだ名だろ！ 僕のかわいい星くず君！ 僕のちっちゃなかわいい星くず君！",
        "checked": true
    },
    {
        "en_raw": "(Ew. But...)\n\t\t\t\t\t\t\"Just say you don't want to answer, it's fine.\"",
        "en_clean": "(Ew. But...)\t\t\t\t\t\t\"Just say you don't want to answer, it's fine.\"",
        "jp_raw": "(うえっ。だけど...) \"答えたくないなら、そう言えばいい。僕は構わない。\"",
        "jp_clean": "(うえっ。だけど...) \"答えたくないなら、そう言えばいい。僕は構わない。\"",
        "checked": true
    },
    {
        "en_raw": "But it's so much fun to annoy you instead! Distracting people with puns and jokes is the best way to evade stupid questions.",
        "en_clean": "But it's so much fun to annoy you instead! Distracting people with puns and jokes is the best way to evade stupid questions.",
        "jp_raw": "でも、さっきみたいな答えできみをいら立たせる方が、楽しいでしょ！ ダジャレやジョークで気を散らせて、質問をさせないようにするのと同じだよ。",
        "jp_clean": "でも、さっきみたいな答えできみをいら立たせる方が、楽しいでしょ！ ダジャレやジョークで気を散らせて、質問をさせないようにするのと同じだよ。",
        "checked": true
    },
    {
        "en_raw": "(Yeah, you can relate.)",
        "en_clean": "(Yeah, you can relate.)",
        "jp_raw": "(確かに、それは身に覚えがある。)",
        "jp_clean": "(確かに、それは身に覚えがある。)",
        "checked": true
    },
    {
        "en_raw": "\"What do you do, when I'm not here?\"",
        "en_clean": "\"What do you do, when I'm not here?\"",
        "jp_raw": "\"僕がいないとき、きみは何をしているんだ？\"",
        "jp_clean": "\"僕がいないとき、きみは何をしているんだ？\"",
        "checked": true
    },
    {
        "en_raw": "Excuse you, my life doesn't revolve around you! I do loads of things while you're gone.",
        "en_clean": "Excuse you, my life doesn't revolve around you! I do loads of things while you're gone.",
        "jp_raw": "悪いけど、僕の生活はきみを中心にまわってるわけじゃないんだ！ きみがいなくても、することはたっくさんある。",
        "jp_clean": "悪いけど、僕の生活はきみを中心にまわってるわけじゃないんだ！ きみがいなくても、することはたっくさんある。",
        "checked": true
    },
    {
        "en_raw": "Like...  I look at the sky. And, um... I take a nap sometimes. Dream about things.",
        "en_clean": "Like...  I look at the sky. And, um... I take a nap sometimes. Dream about things.",
        "jp_raw": "ほら... 空を見たりとか。それに、えっとぉ... たまに、昼寝もする。夢を見たりね。",
        "jp_clean": "ほら... 空を見たりとか。それに、えっとぉ... たまに、昼寝もする。夢を見たりね。",
        "checked": true
    },
