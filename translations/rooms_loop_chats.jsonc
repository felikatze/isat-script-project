    },
    {
        "en_raw": "(Loop's just too mysterious. Suspicious from head to toe.)",
        "en_clean": "(Loop's just too mysterious. Suspicious from head to toe.)",
        "jp_raw": "(ループには謎が多すぎる。頭のてっぺんから足のつま先まで、謎だらけだ。)",
        "jp_clean": "(ループには謎が多すぎる。頭のてっぺんから足のつま先まで、謎だらけだ。)",
        "checked": true
    },
    {
        "en_raw": "Of course you do. I'm just too mysterious, suspicious from head to toe.",
        "en_clean": "Of course you do. I'm just too mysterious, suspicious from head to toe.",
        "jp_raw": "だろうね。僕には謎が多すぎるし、頭のてっぺんから足のつま先まで謎だらけだ。",
        "jp_clean": "だろうね。僕には謎が多すぎるし、頭のてっぺんから足のつま先まで謎だらけだ。",
        "checked": true
    },
    {
        "en_raw": "So! Lay it on me! I'm so curious as to what you think.",
        "en_clean": "So! Lay it on me! I'm so curious as to what you think.",
        "jp_raw": "だからさ！ 僕に教えてよ！ きみが考えてることを知りたいんだ！",
        "jp_clean": "だからさ！ 僕に教えてよ！ きみが考えてることを知りたいんだ！",
        "checked": true
    },
    {
