[//It's really funny that THIS is the one that broke with the eng
    {
        "en_raw": "Oh, traveling one... Siffrin, was it?",
        "en_clean": "Oh, traveling one... Siffrin, was it?",
        "jp_raw": "あら、旅のお方... シフラン、でしたね？",
        "jp_clean": "あら、旅のお方... シフラン、でしたね？",
        "checked": true
    },
    {
        "en_raw": "I cannot thank you enough for what you've done.",
        "en_clean": "I cannot thank you enough for what you've done.",
        "jp_raw": "あなたの働きにはいくら感謝してもしきれませんわ。",
        "jp_clean": "あなたの働きにはいくら感謝してもしきれませんわ。",
        "checked": true
    },
    {
        "en_raw": "I'm sure you and your companions have a lot to talk about... Why\n                        don't you talk to them, and come back to me?",
        "en_clean": "I'm sure you and your companions have a lot to talk about... Why                       don't you talk to them, and come back to me?",
        "jp_raw": "お仲間たちと積もるお話もあるでしょうから... それが終わったら、また私に話しかけてくださいね。",
        "jp_clean": "お仲間たちと積もるお話もあるでしょうから... それが終わったら、また私に話しかけてくださいね。",
        "checked": true
    },
    {
        "en_raw": "I'd love to have a conversation with one of Vaugarde's saviors,\n                        after all!",
        "en_clean": "I'd love to have a conversation with one of Vaugarde's saviors,                       after all!",
        "jp_raw": "ヴォーガルドの英雄とお話しするのを楽しみにしていますわ！",
        "jp_clean": "ヴォーガルドの英雄とお話しするのを楽しみにしていますわ！",
        "checked": true
    },
    {
        "en_raw": "\"But I'd like to talk to you now--\"",
        "en_clean": "\"But I'd like to talk to you now--\"",
        "jp_raw": "\"でも僕は今すぐお話ししたいんですけど――\"",
        "jp_clean": "\"でも僕は今すぐお話ししたいんですけど――\"",
        "checked": true
    },
    {
        "en_raw": "Now? But you and your friends had such a wonderful journey together!",
        "en_clean": "Now? But you and your friends had such a wonderful journey together!",
        "jp_raw": "今すぐ？ でもあなたはお仲間たちと素敵な旅をしてこられたじゃございませんか！",
        "jp_clean": "今すぐ？ でもあなたはお仲間たちと素敵な旅をしてこられたじゃございませんか！",
        "checked": true
    },
    {
        "en_raw": "And it's about to end! You should go and talk to them!",
        "en_clean": "And it's about to end! You should go and talk to them!",
        "jp_raw": "それが終わろうとしているのですよ！ お話ししてくるべきですわ！",
        "jp_clean": "それが終わろうとしているのですよ！ お話ししてくるべきですわ！",
        "checked": true
    },
    {
        "en_raw": "Don't worry about me! I'll be right here for when you're done\n                        talking to them!",
        "en_clean": "Don't worry about me! I'll be right here for when you're done                       talking to them!",
        "jp_raw": "私のことはお気になさらないで！ ずっとここにいますから、お話しが終わったらいらしてくださいな！",
        "jp_clean": "私のことはお気になさらないで！ ずっとここにいますから、お話しが終わったらいらしてくださいな！",
        "checked": true
    },
    {
        "en_raw": "\"I have to talk to you about--\"",
        "en_clean": "\"I have to talk to you about--\"",
        "jp_raw": "\"あなたと話さないといけないんです――\"",
        "jp_clean": "\"あなたと話さないといけないんです――\"",
        "checked": true
    },
    {
        "en_raw": "Tut tut tut!",
        "en_clean": "Tut tut tut!",
        "jp_raw": "チッチッチッ！",
        "jp_clean": "チッチッチッ！",
        "checked": true
    },
    {
        "en_raw": "This can wait, can't it? I'm sure you and your friends have a lot to\n                        talk about, and so little time left to do so!",
        "en_clean": "This can wait, can't it? I'm sure you and your friends have a lot to                       talk about, and so little time left to do so!",
        "jp_raw": "あとにしましょう、ねっ？ お仲間たちと話すことがたくさんあるのでしょう？ なのに残された時間はほんのわずかですよ！",
        "jp_clean": "あとにしましょう、ねっ？ お仲間たちと話すことがたくさんあるのでしょう？ なのに残された時間はほんのわずかですよ！",
        "checked": true
    },
    {
        "en_raw": "Go on, go on!",
        "en_clean": "Go on, go on!",
        "jp_raw": "さあ行ってらっしゃい！",
        "jp_clean": "さあ行ってらっしゃい！",
        "checked": true
    },
    {
        "en_raw": "\"But you might know something about--\"",
        "en_clean": "\"But you might know something about--\"",
        "jp_raw": "\"でもあなたが知っているかも――\"",
        "jp_clean": "\"でもあなたが知っているかも――\"",
        "checked": true
    },
    {
        "en_raw": "Ohohoho!",
        "en_clean": "Ohohoho!",
        "jp_raw": "おほほほ！",
        "jp_clean": "おほほほ！",
        "checked": true
    },
    {
        "en_raw": "Sorry, I know nothing until you talk to your friends!",
        "en_clean": "Sorry, I know nothing until you talk to your friends!",
        "jp_raw": "あいにくですけれど、あなたがお仲間とお話しするまでは何も知りませんことよ！",
        "jp_clean": "あいにくですけれど、あなたがお仲間とお話しするまでは何も知りませんことよ！",
        "checked": true
    },
    {
        "en_raw": "And quite honestly, it is a little funny to see you get steamed\n                        about this, ohoho!",
        "en_clean": "And quite honestly, it is a little funny to see you get steamed                       about this, ohoho!",
        "jp_raw": "率直に申しますけれど、あなたがそこまで躍起になるのは、見ていて少しおかしいですわね。おほほ！",
        "jp_clean": "率直に申しますけれど、あなたがそこまで躍起になるのは、見ていて少しおかしいですわね。おほほ！",
        "checked": true
    },
    {
        "en_raw": "(You want to cry.)",
        "en_clean": "(You want to cry.)",
        "jp_raw": "(泣きたい気分だ。)",
        "jp_clean": "(泣きたい気分だ。)",
        "checked": true
    },
    {
        "en_raw": "\"Can you PLEASE talk to me?\"",
        "en_clean": "\"Can you PLEASE talk to me?\"",
        "jp_raw": "\"お願いだから話してくれませんか？\"",
        "jp_clean": "\"お願いだから話してくれませんか？\"",
        "checked": true
    },
    {
        "en_raw": "...",
        "en_clean": "...",
        "jp_raw": "...",
        "jp_clean": "...",
        "checked": true
    },
    {
        "en_raw": ". . .",
        "en_clean": ". . .",
        "jp_raw": ". . .",
        "jp_clean": ". . .",
        "checked": true
    },
    {
        "en_raw": "Traveling one... Siffrin... Can't you feel it?",
        "en_clean": "Traveling one... Siffrin... Can't you feel it?",
        "jp_raw": "旅のお方... シフラン... あなたは感じませんこと？",
        "jp_clean": "旅のお方... シフラン... あなたは感じませんこと？",
        "checked": true
    },
    {
        "en_raw": "(Huh?)",
        "en_clean": "(Huh?)",
        "jp_raw": "(へっ？)",
        "jp_clean": "(へっ？)",
        "checked": true
    },
    {
        "en_raw": "If you talk to me... REALLY talk to me...",
        "en_clean": "If you talk to me... REALLY talk to me...",
        "jp_raw": "私と話せば... 本当に話せば...",
        "jp_clean": "私と話せば... 本当に話せば...",
        "checked": true
    },
    {
        "en_raw": "It's all over.",
        "en_clean": "It's all over.",
        "jp_raw": "それでおしまいですわ。",
        "jp_clean": "それでおしまいですわ。",
        "checked": true
    },
    {
        "en_raw": "What \"it\" is, I have no idea...",
        "en_clean": "What \"it\" is, I have no idea...",
        "jp_raw": "何がおしまいになるかは分かりませんが...",
        "jp_clean": "何がおしまいになるかは分かりませんが...",
        "checked": true
    },
    {
        "en_raw": "I know... I can feel that... I couldn't change whatever comes next,\n                        even if I wanted to.",
        "en_clean": "I know... I can feel that... I couldn't change whatever comes next,                       even if I wanted to.",
        "jp_raw": "でも... 私は感じるのです... 次に起きることを、私は変えられない。望んでいても、変えられない。",
        "jp_clean": "でも... 私は感じるのです... 次に起きることを、私は変えられない。望んでいても、変えられない。",
        "checked": true
    },
    {
        "en_raw": "But I know it is the will of the Change God.",
        "en_clean": "But I know it is the will of the Change God.",
        "jp_raw": "でもそれがウツロイ様の意志であることは理解していますわ。",
        "jp_clean": "でもそれがウツロイ様の意志であることは理解していますわ。",
        "checked": true
    },
    {
        "en_raw": "Or, no, perhaps... The will of something even bigger...",
        "en_clean": "Or, no, perhaps... The will of something even bigger...",
        "jp_raw": "あるいは、もしかすると... さらに大きな何かの意志...",
        "jp_clean": "あるいは、もしかすると... さらに大きな何かの意志...",
        "checked": true
    },
    {
        "en_raw": ". . .",
        "en_clean": ". . .",
        "jp_raw": ". . .",
        "jp_clean": ". . .",
        "checked": true
    },
    {
        "en_raw": "Something will end, once you talk to me.",
        "en_clean": "Something will end, once you talk to me.",
        "jp_raw": "私と話すことで、何かが終わってしまう。",
        "jp_clean": "私と話すことで、何かが終わってしまう。",
        "checked": true
    },
    {
        "en_raw": "But before this \"something\" ends... Don't you want to talk to your\n                        companions?",
        "en_clean": "But before this \"something\" ends... Don't you want to talk to your                       companions?",
        "jp_raw": "でもその「何か」が終わる前に... お仲間と話したほうがよいのではなくて？",
        "jp_clean": "でもその「何か」が終わる前に... お仲間と話したほうがよいのではなくて？",
        "checked": true
    },
    {
        "en_raw": "So go! Go! Go and talk to everyone!!!",
        "en_clean": "So go! Go! Go and talk to everyone!!!",
        "jp_raw": "ですからお行きなさい。さあ！ みんなとお話しなさい！",
        "jp_clean": "ですからお行きなさい。さあ！ みんなとお話しなさい！",
        "checked": true
    },
    {
        "en_raw": "<span class=\"shake\">\n (...)\n</span>",
        "en_clean": "(...)",
        "jp_raw": "<span class=\"shake\">\n (...)\n</span>",
        "jp_clean": "(...)",
        "checked": true
    },
    {
        "en_raw": "Go on and talk to your companions!",
        "en_clean": "Go on and talk to your companions!",
        "jp_raw": "ほら、お仲間とお話しなさいな！",
        "jp_clean": "ほら、お仲間とお話しなさいな！",
        "checked": true
    },
    {
        "en_raw": "I shall wait right in this very spot!",
        "en_clean": "I shall wait right in this very spot!",
        "jp_raw": "私はここで待っていますわ！",
        "jp_clean": "私はここで待っていますわ！",
        "checked": true
    },
    {
        "en_raw": "(This is the end.)",
        "en_clean": "(This is the end.)",
        "jp_raw": "(これで終わりだ。)",
        "jp_clean": "(これで終わりだ。)",
        "checked": true
    },
    {
        "en_raw": "(Just a little longer...)",
        "en_clean": "(Just a little longer...)",
        "jp_raw": "(あと少しだけ...)",
        "jp_clean": "(あと少しだけ...)",
        "checked": true
    },
    {
        "en_raw": "(Just a moment longer, a minute, a second longer...)",
        "en_clean": "(Just a moment longer, a minute, a second longer...)",
        "jp_raw": "(もうしばらく... 1分でも、1秒でも...)",
        "jp_clean": "(もうしばらく... 1分でも、1秒でも...)",
        "checked": true
    },
    {
        "en_raw": "(Before the curtain falls.)",
        "en_clean": "(Before the curtain falls.)",
        "jp_raw": "(幕が下りてしまう前に。)",
        "jp_clean": "(幕が下りてしまう前に。)",
        "checked": true
    },
    {
        "en_raw": "Traveling one!",
        "en_clean": "Traveling one!",
        "jp_raw": "旅のお方！",
        "jp_clean": "旅のお方！",
        "checked": true
    },
    {
        "en_raw": "Are you done talking with your companions? Yes, wonderful,\n                        wonderful!",
        "en_clean": "Are you done talking with your companions? Yes, wonderful,                       wonderful!",
        "jp_raw": "お仲間とのお話しは終わったのですか？ そう、それはよかった！",
        "jp_clean": "お仲間とのお話しは終わったのですか？ そう、それはよかった！",
        "checked": true
    },
    {
        "en_raw": "I'd like to thank you for accompanying young Mirabelle this far. I'm\n                        very grateful.",
        "en_clean": "I'd like to thank you for accompanying young Mirabelle this far. I'm                       very grateful.",
        "jp_raw": "ここまでミラベルと一緒にいてくださったことにお礼を言わせてください。とても感謝していますわ。",
        "jp_clean": "ここまでミラベルと一緒にいてくださったことにお礼を言わせてください。とても感謝していますわ。",
        "checked": true
    },
    {
        "en_raw": "Siffrin, yes? If there's anything I can do to thank you, please\n                        don't hesitate to let me know!",
        "en_clean": "Siffrin, yes? If there's anything I can do to thank you, please                       don't hesitate to let me know!",
        "jp_raw": "シフラン、でしたわね？ お礼として私にできることがあったら、遠慮なく言ってくださいね！",
        "jp_clean": "シフラン、でしたわね？ お礼として私にできることがあったら、遠慮なく言ってくださいね！",
        "checked": true
    },
    {
        "en_raw": "I know you will go back on your travels soon, but I do hope you'll\n                        keep in touch, if only for young Mirabelle...",
        "en_clean": "I know you will go back on your travels soon, but I do hope you'll                       keep in touch, if only for young Mirabelle...",
        "jp_raw": "もうすぐまた旅に出るのでしたわね？ でもこの先も交流を保てると嬉しいですわ。ミラベルのためにも...",
        "jp_clean": "もうすぐまた旅に出るのでしたわね？ でもこの先も交流を保てると嬉しいですわ。ミラベルのためにも...",
        "checked": true
    },
    {
        "en_raw": "But no matter what, know that Dormont will always be open to you!\n                        Please come back... any... time...",
        "en_clean": "But no matter what, know that Dormont will always be open to you!                       Please come back... any... time...",
        "jp_raw": "いずれにしても、ドーモントはいつでもあなたを歓迎しますわ！ どうぞいつでも... お戻りに... なって...",
        "jp_clean": "いずれにしても、ドーモントはいつでもあなたを歓迎しますわ！ どうぞいつでも... お戻りに... なって...",
        "checked": true
    },
    {
        "en_raw": "<span class=\"shake\">\n ...!!!!!\n</span>",
        "en_clean": "...!!!!!",
        "jp_raw": "<span class=\"shake\">...！！！</span>",
        "jp_clean": "...！！！",
        "checked": true
    },
    {
        "en_raw": "Oh... Oh no. Oh no, no, no, no, no...",
        "en_clean": "Oh... Oh no. Oh no, no, no, no, no...",
        "jp_raw": "ああ... そんな。 ああ、ああ、ああ...",
        "jp_clean": "ああ... そんな。 ああ、ああ、ああ...",
        "checked": true
    },
    {
        "en_raw": "\"...?\"",
        "en_clean": "\"...?\"",
        "jp_raw": "\"...？\"",
        "jp_clean": "\"...？\"",
        "checked": true
    },
    {
        "en_raw": "Oh...   Siffrin...!",
        "en_clean": "Oh...   Siffrin...!",
        "jp_raw": "ごめんなさい！ もう止めようがありませんわ！",
        "jp_clean": "ごめんなさい！ もう止めようがありませんわ！",
        "checked": true
    },
    {
        "en_raw": "I'm so sorry!   There's no way we can stop it now...!",
        "en_clean": "I'm so sorry!   There's no way we can stop it now...!",
        "jp_raw": "ごめんなさいね！ あなたは戻ってしまう！ すべてが始まった時点に！",
        "jp_clean": "ごめんなさいね！ あなたは戻ってしまう！ すべてが始まった時点に！",
        "checked": true
    },
    {
        "en_raw": "I'm sorry! You'll be going back! Back when everything started!",
        "en_clean": "I'm sorry! You'll be going back! Back when everything started!",
        "jp_raw": "ごめんなさいね！ あなたは戻ってしまう！ すべてが始まった時点に！",
        "jp_clean": "ごめんなさいね！ あなたは戻ってしまう！ すべてが始まった時点に！",
        "checked": true
    },
    {
        "en_raw": "(...!)",
        "en_clean": "(...!)",
        "jp_raw": "(...！)",
        "jp_clean": "(...！)",
        "checked": true
    },
    {
        "en_raw": "(The air around you feels weird...)",
        "en_clean": "(The air around you feels weird...)",
        "jp_raw": "(周りの空気がおかしい...)",
        "jp_clean": "(周りの空気がおかしい...)",
        "checked": true
    },
    {
        "en_raw": "(You taste burnt sugar in the back of your throat.)",
        "en_clean": "(You taste burnt sugar in the back of your throat.)",
        "jp_raw": "(焦げた砂糖の味が喉の奥にまとわりつく。)",
        "jp_clean": "(焦げた砂糖の味が喉の奥にまとわりつく。)",
        "checked": true
    },
    {
        "en_raw": "\"What do you mean? What's happening?!?\"",
        "en_clean": "\"What do you mean? What's happening?!?\"",
        "jp_raw": "\"どういうこと？ 何が起きているの？\"",
        "jp_clean": "\"どういうこと？ 何が起きているの？\"",
        "checked": true
    },
    {
        "en_raw": "I know you thought your quest was over, but it can't be!",
        "en_clean": "I know you thought your quest was over, but it can't be!",
        "jp_raw": "あなたたちの旅は終わったと考えているでしょうが、それはありえません！",
        "jp_clean": "あなたたちの旅は終わったと考えているでしょうが、それはありえません！",
        "checked": true
    },
    {
        "en_raw": "Something's broken, something's failing, rotting!!!",
        "en_clean": "Something's broken, something's failing, rotting!!!",
        "jp_raw": "何かが壊れています、破綻しています、腐敗しています！",
        "jp_clean": "何かが壊れています、破綻しています、腐敗しています！",
        "checked": true
    },
    {
        "en_raw": "I can't fix it on my own, not before it all ends... If only I had\n                        noticed sooner!!!",
        "en_clean": "I can't fix it on my own, not before it all ends... If only I had                       noticed sooner!!!",
        "jp_raw": "私だけの力では直せません。その前に終わってしまう... もっと早く気づいていれば！",
        "jp_clean": "私だけの力では直せません。その前に終わってしまう... もっと早く気づいていれば！",
        "checked": true
    },
    {
        "en_raw": "I should've seen it, prevented it!!!",
        "en_clean": "I should've seen it, prevented it!!!",
        "jp_raw": "気づいて、防いでおくべきでした！",
        "jp_clean": "気づいて、防いでおくべきでした！",
        "checked": true
    },
    {
        "en_raw": "(You feel a tug on your stomach.)",
        "en_clean": "(You feel a tug on your stomach.)",
        "jp_raw": "(胃がひっくり返りそうだ。)",
        "jp_clean": "(胃がひっくり返りそうだ。)",
        "checked": true
    },
    {
        "en_raw": "It's my fault that you have to suffer like this.",
        "en_clean": "It's my fault that you have to suffer like this.",
        "jp_raw": "あなたがこうやって苦しむのは、私のせいですわ。",
        "jp_clean": "あなたがこうやって苦しむのは、私のせいですわ。",
        "checked": true
    },
    {
        "en_raw": "I just hope that one day...",
        "en_clean": "I just hope that one day...",
        "jp_raw": "願わくば、いつの日か...",
        "jp_clean": "願わくば、いつの日か...",
        "checked": true
    },
    {
        "en_raw": "You might learn to for",
        "en_clean": "You might learn to for",
        "jp_raw": "私を許し",
        "jp_clean": "私を許し",
        "checked": true
    },
    {
        "en_raw": "(It's the same so far...)",
        "en_clean": "(It's the same so far...)",
        "jp_raw": "(今のところは変わらない...)",
        "jp_clean": "(今のところは変わらない...)",
        "checked": true
    },
    {
        "en_raw": "(You should ask her something, quickly, in case the loops restarts\n                        on its own again.)",
        "en_clean": "(You should ask her something, quickly, in case the loops restarts                       on its own again.)",
        "jp_raw": "(またループが始まるかもしれない。急いで質問したほうがいい。)",
        "jp_clean": "(またループが始まるかもしれない。急いで質問したほうがいい。)",
        "checked": true
    },
    {
        "en_raw": "(Something like...)",
        "en_clean": "(Something like...)",
        "jp_raw": "(たとえば...)",
        "jp_clean": "(たとえば...)",
        "checked": true
    },
    {
        "en_raw": "\"You said something was broken, what was it?\"",
        "en_clean": "\"You said something was broken, what was it?\"",
        "jp_raw": "\"何かが壊れているって言ってたけど、何が壊れてるんです？\"",
        "jp_clean": "\"何かが壊れているって言ってたけど、何が壊れてるんです？\"",
        "checked": true
    },
    {
