        "checked": true
    },
    {
        "en_raw": "<span class=\"shake\">\n And if you do not remember your past......\n</span>",
        "en_clean": "And if you do not remember your past......",
        "jp_raw": "<span class=\"shake\">自分の過去を思い出せないなら......</span>",
