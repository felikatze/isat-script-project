        "checked": true
    },
    {
        "en_raw": "<span class=\"shake\">\n They're proof that we existed.\n <br/>\n That we are real.\n</span>",
        "en_clean": "They're proof that we existed.That we are real.",
        "jp_raw": "<span class=\"shake\">記憶こそが、私たちがいた証だ。<br>自分が現実の存在であるという証拠なのだ。</span>",
        "jp_clean": "記憶こそが、私たちがいた証だ。自分が現実の存在であるという証拠なのだ。",
        "checked": true
    },
    {
