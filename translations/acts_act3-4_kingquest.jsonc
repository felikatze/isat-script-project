        "checked": true
    },
    {
        "en_raw": "<span class=\"shake\">\n How I got here, why I didn't recognize my surroundings......\n</span>",
        "en_clean": "How I got here, why I didn't recognize my surroundings......",
        "jp_raw": "<span class=\"shake\">どうやってここにたどり着いたのか、なぜ周囲の風景に見覚えがないのか......</span>",
        "jp_clean": "どうやってここにたどり着いたのか、なぜ周囲の風景に見覚えがないのか......",
        "checked": true
    },
    {
        "en_raw": "<span class=\"shake\">\n My past, my family, my name, the language I spoke, the alphabet I wrote with, the stars, the country's inhabitants, culture, beliefs, its very name......!!!\n</span>",
        "en_clean": "My past, my family, my name, the language I spoke, the alphabet I wrote with, the stars, the country's inhabitants, culture, beliefs, its very name......!!!",
        "jp_raw": "<span class=\"shake\">自分の過去も、家族も、名前も、母国語も、読み書きする文字も、星も、国の住民も、文化も、信仰も、国の名前すらも......！！！</span>",
        "jp_clean": "自分の過去も、家族も、名前も、母国語も、読み書きする文字も、星も、国の住民も、文化も、信仰も、国の名前すらも......！！！",
