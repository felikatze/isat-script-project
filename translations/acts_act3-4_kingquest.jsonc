        "checked": true
    },
    {
        "en_raw": "<span class=\"shake\">\n And as I realized nothing came to mind, I also realized......\n</span>",
        "en_clean": "And as I realized nothing came to mind, I also realized......",
        "jp_raw": "<span class=\"shake\">何も思い浮かばないことに気づき、そして悟った......</span>",
        "jp_clean": "何も思い浮かばないことに気づき、そして悟った......",
        "checked": true
    },
    {
        "en_raw": "<span class=\"shake\">\n I could not remember a single thing.\n</span>",
        "en_clean": "I could not remember a single thing.",
        "jp_raw": "<span class=\"shake\">何も、何ひとつとして、まったく思い出せないと。</span>",
        "jp_clean": "何も、何ひとつとして、まったく思い出せないと。",
        "checked": true
    },
    {
        "en_raw": "<span class=\"shake\">\n What I was doing here on this beach, what chores I had to do on that day......\n</span>",
