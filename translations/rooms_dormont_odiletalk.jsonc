    },
    {
        "en_raw": "...",
        "en_clean": "...",
        "jp_raw": "...",
        "jp_clean": "...",
        "checked": true
    },
    {
        "en_raw": "Nonetheless, I'll be there. Poor Boniface probably needs it. Maybe we all do.",
        "en_clean": "Nonetheless, I'll be there. Poor Boniface probably needs it. Maybe we all do.",
        "jp_raw": "まあ、参加するよ。かわいそうなボニファスには必要だろうから。私たちみんなに必要かもしれないな。",
        "jp_clean": "まあ、参加するよ。かわいそうなボニファスには必要だろうから。私たちみんなに必要かもしれないな。",
        "checked": true
    },
    {
        "en_raw": "But the room only has three beds, right? I better get a whole bed to myself.",
        "en_clean": "But the room only has three beds, right? I better get a whole bed to myself.",
