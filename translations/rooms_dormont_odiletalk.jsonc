    },
    {
        "en_raw": "(Didn't work so well the first time...)",
        "en_clean": "(Didn't work so well the first time...)",
        "jp_raw": "(1度目はうまくいかなかった...)",
        "jp_clean": "(1度目はうまくいかなかった...)",
        "checked": false
    },
    {
        "en_raw": "(You're kind of glad it's your job...)",
        "en_clean": "(You're kind of glad it's your job...)",
        "jp_raw": "(それが自分の役目でよかった...)",
        "jp_clean": "(それが自分の役目でよかった...)",
        "checked": false
    },
    {
        "en_raw": "(It's your role, after all.)",
        "en_clean": "(It's your role, after all.)",
        "jp_raw": "(結局、それが僕の役割だ。)",
        "jp_clean": "(結局、それが僕の役割だ。)",
        "checked": false
    },
    {
        "en_raw": "Leading everyone, if possible. You've already proven good at preventing traps and keeping us alive, so I don't see why that has to change.",
        "en_clean": "Leading everyone, if possible. You've already proven good at preventing traps and keeping us alive, so I don't see why that has to change.",
        "jp_raw": "よければ、みんなを先導してくれ。罠を回避して、みんなを助けてきてくれただろう？ それを変える必要はないと思う。",
        "jp_clean": "よければ、みんなを先導してくれ。罠を回避して、みんなを助けてきてくれただろう？ それを変える必要はないと思う。",
        "checked": true
    },
    {
        "en_raw": "And as always, you can count on me to provide everyone with intel on any enemies we encounter.",
        "en_clean": "And as always, you can count on me to provide everyone with intel on any enemies we encounter.",
        "jp_raw": "それに、遭遇する敵の情報については、いつもどおり私を頼ってくれていい。",
        "jp_clean": "それに、遭遇する敵の情報については、いつもどおり私を頼ってくれていい。",
        "checked": true
    },
    {
        "en_raw": "Everyone except Boniface will be on battle duty... But I might ask Boniface to do something as well.",
        "en_clean": "Everyone except Boniface will be on battle duty... But I might ask Boniface to do something as well.",
        "jp_raw": "ボニファス以外は戦闘に加わるが... ボニファスにも何か頼むかもしれない。",
        "jp_clean": "ボニファス以外は戦闘に加わるが... ボニファスにも何か頼むかもしれない。",
        "checked": true
    },
    {
        "en_raw": "It might be good for everyone to give the kid something to do...",
        "en_clean": "It might be good for everyone to give the kid something to do...",
        "jp_raw": "子どもに何か仕事を与えておくのは、きっといいことだ...",
        "jp_clean": "子どもに何か仕事を与えておくのは、きっといいことだ...",
        "checked": true
    },
    {
        "en_raw": "...Boring tactics talk, I know. I'll shut up and buy items for our journey to the top of the House.",
        "en_clean": "...Boring tactics talk, I know. I'll shut up and buy items for our journey to the top of the House.",
        "jp_raw": "...戦術の話など、つまらないな。おしゃべりは終わりにして、館の最上階へ向かうのに必要なアイテムを買うとしよう。",
        "jp_clean": "...戦術の話など、つまらないな。おしゃべりは終わりにして、館の最上階へ向かうのに必要なアイテムを買うとしよう。",
        "checked": true
    },
