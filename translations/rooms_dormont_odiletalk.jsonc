    },
    {//TODO eng missing response
        "en_raw": "",
        "en_clean": "",
        "jp_raw": "\"ミラとボニーが一緒に寝て...\"",
        "jp_clean": "\"ミラとボニーが一緒に寝て...\"",
        "checked": false
    },
    {
        "en_raw": "",
        "en_clean": "",
        "jp_raw": null,
        "jp_clean": null,
        "checked": false
    },
    {
        "en_raw": "Mirabelle and Bonnie? So who'll sleep on the ground, you or Isabeau?",
        "en_clean": "Mirabelle and Bonnie? So who'll sleep on the ground, you or Isabeau?",
        "jp_raw": "ミラベルとボニーが？ それじゃ、床で寝るのはどっちだ？ きみか、イザボーか？",
        "jp_clean": "ミラベルとボニーが？ それじゃ、床で寝るのはどっちだ？ きみか、イザボーか？",
        "checked": true
    },
    {//TODO this and next choicer "\"僕とイザは一緒に寝るよ？\"" "\"もちろんイザだよ。\""
        "en_raw": "",
        "en_clean": "",
        "jp_raw": null,
        "jp_clean": null,
        "checked": false
    },
    {
        "en_raw": "",
        "en_clean": "",
        "jp_raw": null,
        "jp_clean": null,
        "checked": false
    },
    {
        "en_raw": "...Fascinating.",
        "en_clean": "...Fascinating.",
        "jp_raw": "...面白い。",
        "jp_clean": "...面白い。",
        "checked": true
    },
    {
        "en_raw": "Poor man.",
        "en_clean": "Poor man.",
        "jp_raw": "...おもしろい。",
        "jp_clean": "...おもしろい。",
        "checked": true
    },
    {
        "en_raw": "...Anyway, I'll be there. You know, since we already decided earlier we'd meet at the Clocktower and all.",
        "en_clean": "...Anyway, I'll be there. You know, since we already decided earlier we'd meet at the Clocktower and all.",
        "jp_raw": "...とにかく、後で行くよ。時計台に集合というのは、もう決めてあったんだし。",
        "jp_clean": "...とにかく、後で行くよ。時計台に集合というのは、もう決めてあったんだし。",
        "checked": true
    },
    {
        "en_raw": "(Yeah... You already all planned to meet up at the Clocktower, so was there a need for you to let everyone know?)",
        "en_clean": "(Yeah... You already all planned to meet up at the Clocktower, so was there a need for you to let everyone know?)",
        "jp_raw": "(そうだ... 待ち合わせは時計台って決めてあったのに、みんなに知らせてまわる必要なんてあったのか？)",
        "jp_clean": "(そうだ... 待ち合わせは時計台って決めてあったのに、みんなに知らせてまわる必要なんてあったのか？)",
        "checked": true
    },
    {
        "en_raw": "(You could've just met everyone at the Clocktower...)",
        "en_clean": "(You could've just met everyone at the Clocktower...)",
        "jp_raw": "(時計台でみんなを待ってればよかったじゃないか...)",
        "jp_clean": "(時計台でみんなを待ってればよかったじゃないか...)",
        "checked": true
    },
    {
        "en_raw": "(Oh well. Not like you have anything better to do.)",
        "en_clean": "(Oh well. Not like you have anything better to do.)",
        "jp_raw": "(まあいいや。他にすることもないし。)",
        "jp_clean": "(まあいいや。他にすることもないし。)",
        "checked": true
    },
    {
        "en_raw": "(Hm... Guess you don't have to talk to everyone again.)",
        "en_clean": "(Hm... Guess you don't have to talk to everyone again.)",
        "jp_raw": "(ふむ... みんなともう一度話さなくてもよさそうだ。)",
        "jp_clean": "(ふむ... みんなともう一度話さなくてもよさそうだ。)",
        "checked": true
    },
    {
        "en_raw": "(You REALLY don't have to talk to everyone again.)",
        "en_clean": "(You REALLY don't have to talk to everyone again.)",
        "jp_raw": "(みんなともう一度話す必要は本当にないんだ。)",
        "jp_clean": "(みんなともう一度話す必要は本当にないんだ。)",
        "checked": true
    },
    {
        "en_raw": "...Anything else?",
        "en_clean": "...Anything else?",
        "jp_raw": "...他に何か？",
        "jp_clean": "...他に何か？",
        "checked": true
    },
    {
        "en_raw": "(You suppose you don't need to tell her every time...)",
        "en_clean": "(You suppose you don't need to tell her every time...)",
        "jp_raw": "(オディールに毎回言う必要はないだろう...)",
        "jp_clean": "(オディールに毎回言う必要はないだろう...)",
        "checked": true
    },
    {
        "en_raw": "We are. I hope you're prepared.",
        "en_clean": "We are. I hope you're prepared.",
        "jp_raw": "そうだな。ちゃんと準備ができていることを願うよ。",
        "jp_clean": "そうだな。ちゃんと準備ができていることを願うよ。",
        "checked": true
    },
    {
        "en_raw": "The King, and the Sadnesses his destruction creates... They possess Crafts capable of slowing us down, or even freezing us in time completely.",
        "en_clean": "The King, and the Sadnesses his destruction creates... They possess Crafts capable of slowing us down, or even freezing us in time completely.",
        "jp_raw": "王と、王の破壊が作り出した哀し身... 彼らは私たちの時間をスローダウンさせたり、時間を完全に止めたりできるクラフトの力を持っている。",
        "jp_clean": "王と、王の破壊が作り出した哀し身... 彼らは私たちの時間をスローダウンさせたり、時間を完全に止めたりできるクラフトの力を持っている。",
        "checked": true
    },
    {
        "en_raw": "So, as always, we're counting on you and your speed to keep us out of trouble.",
        "en_clean": "So, as always, we're counting on you and your speed to keep us out of trouble.",
        "jp_raw": "つまり、明日もきみが頼りだ。きみのスピードが決め手になる。",
        "jp_clean": "つまり、明日もきみが頼りだ。きみのスピードが決め手になる。",
        "checked": true
    },
    {//TODO eng response missing this and next 3 lines "\"...つまり、僕にまた先頭になれって？\""
        "en_raw": "(Aw...)",
        "en_clean": "(Aw...)",
        "jp_raw": "(うう...) \"...つまり、僕にまた先頭になれって？\"",
        "jp_clean": "(うう...)\"...つまり、僕にまた先頭になれって？\"",
