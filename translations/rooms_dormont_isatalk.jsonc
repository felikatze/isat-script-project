    },
    {
        "en_raw": "Hey, uh, Sif? Are you still half-asleep?",
        "en_clean": "Hey, uh, Sif? Are you still half-asleep?",
        "jp_raw": "なあ、シフ？ まだ半分寝てるのか？",
