        "checked": true
    },
    {
        "en_raw": "You should stop taking forever naps, Sif. Naps give you cotton brain.",
        "en_clean": "You should stop taking forever naps, Sif. Naps give you cotton brain.",
        "jp_raw": "長く昼寝するのはやめた方がいいぞ。頭がぼんやりしちゃうからな。",
        "jp_clean": "長く昼寝するのはやめた方がいいぞ。頭がぼんやりしちゃうからな。",
        "checked": true
    },
    {
        "en_raw": "Sif. Woke up on the wrong side of the bed? I get it.",
        "en_clean": "Sif. Woke up on the wrong side of the bed? I get it.",
        "jp_raw": "シフ。寝起きが悪かったか？ そういうときもあるよな。",
